#!/usr/bin/env bash
set -euo pipefail

# --- Usage ---
usage() {
  cat <<EOF
Usage: agentic <command> [args...]

Build, clean, and run agentic tools in sandboxed Docker containers.

Commands:
  build        Build tool image(s)
  update       Update tool image(s) to latest version
  clean        Remove tool image(s)
  inspect      Show image info
  volumes      Manage named Docker volumes
  completion   Print shell completion script
  aliases      Print shell alias definitions for tools
  help         Show help for a command
  <tool>       Run a tool (claude, copilot, opencode)
               Use 'agentic help run' for run options.

Run 'agentic help <command>' for command-specific help.
EOF
}

usage_build() {
  cat <<EOF
Usage: agentic build [tool] [options]

Build tool image(s). Builds all tools if no tool specified.

Options:
  --base <extra[,extra]>  Override the extra runtime(s) to layer on top of node.
  --no-cache              Disable Docker layer cache for a fully fresh build.
  --node <version>        Node.js version (default: 24).
  --java <version>        Java (Temurin JDK) version (default: 21).
  --dotnet <version>      .NET version (default: 10).

Environment:
  AGENTIC_NODE_VERSION    Node.js version (overridden by --node)
  AGENTIC_JAVA_VERSION    Java version (overridden by --java)
  AGENTIC_DOTNET_VERSION  .NET version (overridden by --dotnet)

Examples:
  agentic build
  agentic build claude
  agentic build claude --base java
  agentic build --node 22
  agentic build claude --base java --java 17
  AGENTIC_NODE_VERSION=22 agentic build
  AGENTIC_JAVA_VERSION=17 agentic build claude --base java
EOF
}

usage_update() {
  cat <<EOF
Usage: agentic update [tool] [options]

Update tool image(s) to latest version. Rebuilds the tool step without cache
so the installer fetches the latest version. Skips unbuilt tools when no tool
specified.

Options:
  --base <extra[,extra]>  Override the extra runtime(s) to layer on top of node.
  --no-cache              Also rebuild base layers (fully fresh build).
  --node <version>        Node.js version (default: 24).
  --java <version>        Java (Temurin JDK) version (default: 21).
  --dotnet <version>      .NET version (default: 10).

Examples:
  agentic update
  agentic update claude
  agentic update claude --base java
  agentic update claude --no-cache
EOF
}


usage_completion() {
  cat <<EOF
Usage: agentic completion [shell]

Print shell completion script. Supported shells: bash, zsh (default).
Eval or source the output to activate completions.

Examples:
  source <(agentic completion zsh)   # add to .zshrc
  source <(agentic completion bash)  # add to .bashrc
EOF
}

# --- Dependencies ---
# Resolve symlinks so this works when installed via a symlink (e.g. ~/.local/bin/agentic)
_SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=../shared/scripts/repo-root.sh
source "$_SCRIPT_DIR/../shared/scripts/repo-root.sh"

# --- Helpers ---
# Enumerate available tools by scanning tools/*/config.sh.
list_tools() {
  for config in "$REPO_ROOT/tools"/*/config.sh; do
    basename "$(dirname "$config")"
  done
}

# Run a build or clean script for a single tool.
run_tool_script() {
  local cmd="$1" tool="$2"
  local script="$REPO_ROOT/tools/$tool/$cmd.sh"
  if [[ ! -f "$script" ]]; then
    echo "Error: unknown tool '$tool'"
    exit 1
  fi
  echo "=> $tool"
  bash "$script"
}

# Source a tool's config and echo its IMAGE name. Always call via $() to isolate side effects.
tool_image() {
  local config="$REPO_ROOT/tools/$1/config.sh"
  source "$config"
  echo "$IMAGE"
}

get_tool_version() {
  local tool="$1"
  local image
  image=$(tool_image "$tool")
  docker inspect --format '{{index .Config.Labels "agentic.tool.version"}}' "$image" 2>/dev/null || true
}

is_tool_built() {
  local image
  image=$(tool_image "$1")
  docker image inspect "$image" >/dev/null 2>&1
}

parse_build_args() {
  local cmd="$1"
  shift
  TOOL_ARG=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --base)
      if [[ -z "${2:-}" ]]; then
        echo "Error: --base requires a value"
        exit 1
      fi
      export AGENTIC_BASE_OVERRIDE="$2"
      shift 2
      ;;
    --no-cache)
      export AGENTIC_NO_CACHE=1
      shift
      ;;
    --node)
      if [[ -z "${2:-}" ]]; then
        echo "Error: --node requires a version"
        exit 1
      fi
      export AGENTIC_NODE_VERSION="$2"
      shift 2
      ;;
    --java)
      if [[ -z "${2:-}" ]]; then
        echo "Error: --java requires a version"
        exit 1
      fi
      export AGENTIC_JAVA_VERSION="$2"
      shift 2
      ;;
    --dotnet)
      if [[ -z "${2:-}" ]]; then
        echo "Error: --dotnet requires a version"
        exit 1
      fi
      export AGENTIC_DOTNET_VERSION="$2"
      shift 2
      ;;
    -*)
      echo "Error: unknown $cmd option '$1'"
      exit 1
      ;;
    *)
      TOOL_ARG="$1"
      shift
      ;;
    esac
  done
}

prune_images() {
  local prune_out reclaimed
  prune_out=$(docker image prune -f 2>&1)
  reclaimed=$(echo "$prune_out" | awk '/Total reclaimed space:/ {print $NF}')
  if [[ -n "$reclaimed" && "$reclaimed" != "0B" ]]; then
    echo "=> pruned dangling images (reclaimed $reclaimed)"
  fi
}

# --- Volumes ---
usage_volumes() {
  cat <<EOF
Usage: agentic volumes <subcommand>

Manage named Docker volumes created by agentic.

Subcommands:
  create <name>  Create a named volume
  list, ls       List all agentic-managed volumes
  remove, rm     Remove an agentic-managed volume, or all if no name given

Examples:
  agentic volumes create maven
  agentic volumes list
  agentic volumes remove maven
  agentic volumes remove
EOF
}

ensure_volume() {
  docker volume create --label "project=agentic-cli" "$1" >/dev/null
}

create_volume() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "Error: volumes create requires a name"
    exit 1
  fi
  ensure_volume "$name"
  echo "=> created: $name"
}

list_volumes() {
  docker volume ls --filter "label=project=agentic-cli"
}

remove_volume() {
  local name="${1:-}"
  if [[ -n "$name" ]]; then
    local label
    label=$(docker volume inspect --format '{{index .Labels "project"}}' "$name" 2>/dev/null || true)
    if [[ "$label" != "agentic-cli" ]]; then
      echo "Error: '$name' is not an agentic-managed volume"
      exit 1
    fi
    docker volume rm "$name" | sed 's/^/=> deleted: /'
  else
    local volumes
    volumes=$(docker volume ls -q --filter "label=project=agentic-cli")
    if [[ -z "$volumes" ]]; then
      echo "No agentic-managed volumes found."
    else
      echo "Volumes to remove:"
      echo "$volumes" | sed 's/^/  /'
      read -r -p "Remove all agentic-managed volumes? [y/N] " confirm
      [[ "$confirm" =~ ^[Yy]$ ]] || exit 0
      echo "$volumes" | xargs docker volume rm | sed 's/^/=> deleted: /'
    fi
  fi
}

cmd_volumes() {
  local subcmd="${1:-}"
  case "$subcmd" in
  create) create_volume "${@:2}" ;;
  list | ls) list_volumes ;;
  remove | rm) remove_volume "${@:2}" ;;
  "" | -h | --help) usage_volumes ;;
  *)
    echo "Error: unknown volumes subcommand '${subcmd}'"
    echo ""
    usage_volumes
    exit 1
    ;;
  esac
}

# --- Build ---
cmd_build() {
  local tool="${1:-}"
  if [[ -n "$tool" ]]; then
    run_tool_script build "$tool"
  else
    for script in "$REPO_ROOT/tools"/*/build.sh; do
      run_tool_script build "$(basename "$(dirname "$script")")"
    done
  fi
}

# --- Update ---
report_version_change() {
  local before="$1" after="$2"
  if [[ -n "$before" && "$before" != "$after" ]]; then
    echo "=> version: $before -> $after"
  elif [[ -n "$after" ]]; then
    echo "=> version: $after (up to date)"
  fi
}

update_tool() {
  local tool="$1"
  local before after
  before=$(get_tool_version "$tool")
  run_tool_script update "$tool"
  after=$(get_tool_version "$tool")
  report_version_change "$before" "$after"
}

cmd_update() {
  local tool="${1:-}"

  if [[ -n "$tool" ]]; then
    update_tool "$tool"
  else
    local updated=0

    for script in "$REPO_ROOT/tools"/*/update.sh; do
      local t
      t="$(basename "$(dirname "$script")")"

      if ! is_tool_built "$t"; then
        echo "=> $t (skipped - not built)"
        continue
      fi

      update_tool "$t"
      updated=1
    done

    if [[ "$updated" -eq 0 ]]; then
      echo "No tools are built. Run 'agentic build' first."
    fi
  fi
}

# --- Clean ---
# --- Help ---
handle_help() {
  local cmd="$1" flag="${2:-}"
  if [[ "$flag" == "-h" || "$flag" == "--help" ]]; then
    cmd_help "$cmd"
    exit 0
  fi
}

cmd_help() {
  case "${1:-}" in
  build) usage_build ;;
  update) usage_update ;;
  clean) exec agentic-cli clean --help ;;
  inspect) exec agentic-cli inspect --help ;;
  volumes) usage_volumes ;;
  completion) usage_completion ;;
  aliases) exec agentic-cli aliases --help ;;
  run) exec agentic-cli run --help ;;
  help | "") usage ;;
  *)
    echo "Error: unknown command '${1}'"
    echo ""
    usage
    exit 1
    ;;
  esac
}

# --- Completion ---
cmd_completion() {
  local shell="${1:-zsh}"

  # Collect tools at generation time so the script stays up to date with the
  # actual tools/ directory rather than a hard-coded list.
  local tools
  tools="$(list_tools | tr '\n' ' ')"

  case "$shell" in
  zsh)
    cat <<'PREAMBLE'
# agentic zsh completion - generated by: agentic completion zsh
# Add to .zshrc:  source <(agentic completion zsh)
PREAMBLE
    cat <<BODY
_agentic() {
  local state

  _arguments -C \\
    '(-h --help)'{-h,--help}'[show help]' \\
    '--home[override tool home directory]:directory:_directories' \\
    '(--volume -v)'{--volume,-v}'[mount extra volume (bind or named volume)]:spec' \\
    '--pids-limit[override container PID limit]:limit' \\
    '--cpus[override CPU limit]:cpus' \\
    '--memory[override memory limit]:size' \\
    '1: :->command' \\
    '*:: :->args'

  case \$state in
    command)
      local -a commands
      if (( \${+opt_args[--home]} || \${+opt_args[--volume]} || \${+opt_args[-v]} || \${+opt_args[--pids-limit]} || \${+opt_args[--cpus]} || \${+opt_args[--memory]} )); then
        commands=(
$(for t in $tools; do printf "          '%s:run the %s CLI'\n" "$t" "$t"; done)
        )
        _describe 'tool' commands
      else
        commands=(
          'build:build tool image(s)'
          'clean:remove tool image(s)'
          'inspect:show image info'
          'update:update tool image(s) to latest version'
          'volumes:manage named Docker volumes'
          'completion:print shell completion script'
          'aliases:print shell alias definitions for tools'
          'help:show help for a command'
$(for t in $tools; do printf "          '%s:run the %s CLI'\n" "$t" "$t"; done)
        )
        _describe 'command' commands
      fi
      ;;

    args)
      case \$words[1] in
        build)
          _arguments \\
            '(-h --help)'{-h,--help}'[show help]' \\
            '--base[override extra runtimes]:extras' \\
            '--no-cache[disable Docker layer cache]' \\
            '--node[Node.js version to use]:version' \\
            '--java[Java (Temurin JDK) version to use]:version' \\
            '--dotnet[Dotnet version to use]:version' \\
            ": :(($(for t in $tools; do printf "%s:'build the %s image' " "$t" "$t"; done)))"
          ;;
        update)
          _arguments \\
            '(-h --help)'{-h,--help}'[show help]' \\
            '--base[override extra runtimes]:extras' \\
            '--no-cache[disable Docker layer cache for all steps]' \\
            '--node[Node.js version to use]:version' \\
            '--java[Java (Temurin JDK) version to use]:version' \\
            '--dotnet[Dotnet version to use]:version' \\
            ": :(($(for t in $tools; do printf "%s:'update the %s image' " "$t" "$t"; done)))"
          ;;
        clean|inspect)
          _arguments '(-h --help)'{-h,--help}'[show help]' ": :(($(for t in $tools; do printf "%s:'%s' " "$t" "$t"; done)))"
          ;;
        volumes)
          case \$words[2] in
            remove|rm)
              local vols
              vols=(\${(f)"\$(docker volume ls -q --filter 'label=project=agentic-cli' 2>/dev/null)"})
              _describe 'volume' vols
              ;;
            *)
              _arguments ": :(create list ls remove rm)"
              ;;
          esac
          ;;
        help)
          _arguments ": :(build update clean inspect volumes completion aliases run)"
          ;;
        completion)
          _arguments '(-h --help)'{-h,--help}'[show help]' ": :(bash zsh)"
          ;;
        *)
          if (( \${words[(I)--]} )); then
            _command_names -e
          elif [[ \$words[1] == -* ]]; then
            _arguments \\
              '(-h --help)'{-h,--help}'[show help]' \\
              '--home[override tool home directory]:directory:_directories' \\
              '(--volume -v)'{--volume,-v}'[mount extra volume (bind or named volume)]:spec' \\
              '--pids-limit[override container PID limit]:limit' \\
              '--cpus[override CPU limit]:cpus' \\
              '--memory[override memory limit]:size' \\
              ": :(($(for t in $tools; do printf "%s:'run the %s CLI' " "$t" "$t"; done)))"
          else
            _arguments ': :(--)'
          fi
          ;;
      esac
      ;;
  esac
}

compdef _agentic agentic
BODY
    ;;

  bash)
    cat <<'PREAMBLE'
# agentic bash completion - generated by: agentic completion bash
# Add to .bashrc:  source <(agentic completion bash)
PREAMBLE
    cat <<BODY
_agentic_complete() {
  local cur prev
  cur="\${COMP_WORDS[COMP_CWORD]}"
  prev="\${COMP_WORDS[COMP_CWORD-1]}"

  local tools="${tools}"
  local commands="build clean inspect update volumes completion aliases help \${tools}"

  if [[ \$COMP_CWORD -eq 1 ]]; then
    COMPREPLY=(\$(compgen -W "--help \${commands}" -- "\$cur"))
    return
  fi

  case "\${COMP_WORDS[1]}" in
    build)
      case "\$prev" in
        --base|--node|--java|--dotnet) COMPREPLY=(); return ;;
        *)      COMPREPLY=(\$(compgen -W "\${tools} --base --no-cache --node --java --dotnet --help" -- "\$cur")) ;;
      esac
      ;;
    update)
      case "\$prev" in
        --base|--node|--java|--dotnet) COMPREPLY=(); return ;;
        *)      COMPREPLY=(\$(compgen -W "\${tools} --base --no-cache --node --java --dotnet --help" -- "\$cur")) ;;
      esac
      ;;
    clean|inspect)
      COMPREPLY=(\$(compgen -W "\${tools} --help" -- "\$cur"))
      ;;
    volumes)
      case "\${COMP_WORDS[2]}" in
        remove|rm)
          local vols
          vols=\$(docker volume ls -q --filter "label=project=agentic-cli" 2>/dev/null)
          COMPREPLY=(\$(compgen -W "\$vols" -- "\$cur"))
          ;;
        *)
          COMPREPLY=(\$(compgen -W "create list ls remove rm" -- "\$cur"))
          ;;
      esac
      ;;
    help)
      COMPREPLY=(\$(compgen -W "build update clean inspect volumes completion aliases run" -- "\$cur"))
      ;;
    completion)
      COMPREPLY=(\$(compgen -W "bash zsh --help" -- "\$cur"))
      ;;
    *)
      local i has_dashdash=0
      for (( i=1; i<COMP_CWORD; i++ )); do
        [[ "\${COMP_WORDS[i]}" == "--" ]] && has_dashdash=1 && break
      done
      if [[ "\$has_dashdash" -eq 1 ]]; then
        COMPREPLY=(\$(compgen -c -- "\$cur"))
      elif [[ "\${COMP_WORDS[1]}" == -* ]]; then
        case "\$prev" in
          --home) COMPREPLY=(\$(compgen -d -- "\$cur")); return ;;
          --pids-limit|--cpus|--memory|--volume|-v) COMPREPLY=(); return ;;
        esac
        COMPREPLY=(\$(compgen -W "\${tools} --help --home --volume -v --pids-limit --cpus --memory" -- "\$cur"))
      else
        COMPREPLY=(\$(compgen -W "--" -- "\$cur"))
      fi
      ;;
  esac
}

complete -F _agentic_complete agentic
BODY
    ;;

  *)
    echo "Error: unsupported shell '$shell'. Supported: bash, zsh" >&2
    exit 1
    ;;
  esac
}

# --- Dispatch ---
# Route build/clean/inspect/completion commands before run-specific argument parsing.
COMMAND="${1:-}"

case "$COMMAND" in
-h | --help)
  usage
  exit 0
  ;;

build)
  handle_help build "${2:-}"
  shift
  parse_build_args build "$@"
  cmd_build "$TOOL_ARG"
  prune_images
  exit 0
  ;;

update)
  handle_help update "${2:-}"
  shift
  parse_build_args update "$@"
  cmd_update "$TOOL_ARG"
  prune_images
  exit 0
  ;;

clean)
  exec agentic-cli clean "${@:2}"
  ;;

inspect)
  exec agentic-cli inspect "${@:2}"
  ;;

completion)
  handle_help completion "${2:-}"
  cmd_completion "${2:-}"
  exit 0
  ;;

aliases)
  exec agentic-cli aliases "${@:2}"
  ;;

volumes)
  handle_help volumes "${2:-}"
  cmd_volumes "${2:-}" "${3:-}"
  exit 0
  ;;

help)
  cmd_help "${2:-}"
  exit 0
  ;;
esac

# --- Run ---
if ! command -v agentic-cli >/dev/null 2>&1; then
  echo "Error: agentic-cli not found on PATH. Install it with 'make install'."
  exit 1
fi
exec agentic-cli run "$@"
