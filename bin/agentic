#!/usr/bin/env bash
set -euo pipefail

# --- Usage ---
usage() {
  cat <<EOF
Usage: agentic <command> [args...]

Build, clean, and run agentic tools in sandboxed Docker containers.

Commands:
  build        Build tool image(s)
  update       Update tool image(s) to latest version
  clean        Remove tool image(s)
  inspect      Show image info
  volumes      Manage named Docker volumes
  completion   Print shell completion script
  aliases      Print shell alias definitions for tools
  help         Show help for a command
  <tool>       Run a tool (claude, copilot, opencode)
               Use 'agentic help run' for run options.

Run 'agentic help <command>' for command-specific help.
EOF
}



usage_completion() {
  cat <<EOF
Usage: agentic completion [shell]

Print shell completion script. Supported shells: bash, zsh (default).
Eval or source the output to activate completions.

Examples:
  source <(agentic completion zsh)   # add to .zshrc
  source <(agentic completion bash)  # add to .bashrc
EOF
}

# --- Dependencies ---
# Resolve symlinks so this works when installed via a symlink (e.g. ~/.local/bin/agentic)
_SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=../shared/scripts/repo-root.sh
source "$_SCRIPT_DIR/../shared/scripts/repo-root.sh"

# --- Helpers ---
# Enumerate available tools by scanning tools/*/Dockerfile.
list_tools() {
  for df in "$REPO_ROOT/tools"/*/Dockerfile; do
    basename "$(dirname "$df")"
  done
}

# --- Clean ---
# --- Help ---
handle_help() {
  local cmd="$1" flag="${2:-}"
  if [[ "$flag" == "-h" || "$flag" == "--help" ]]; then
    cmd_help "$cmd"
    exit 0
  fi
}

cmd_help() {
  case "${1:-}" in
  build) exec agentic-cli build --help ;;
  update) exec agentic-cli update --help ;;
  clean) exec agentic-cli clean --help ;;
  inspect) exec agentic-cli inspect --help ;;
  volumes) exec agentic-cli volumes --help ;;
  completion) usage_completion ;;
  aliases) exec agentic-cli aliases --help ;;
  run) exec agentic-cli run --help ;;
  help | "") usage ;;
  *)
    echo "Error: unknown command '${1}'"
    echo ""
    usage
    exit 1
    ;;
  esac
}

# --- Completion ---
cmd_completion() {
  local shell="${1:-zsh}"

  # Collect tools at generation time so the script stays up to date with the
  # actual tools/ directory rather than a hard-coded list.
  local tools
  tools="$(list_tools | tr '\n' ' ')"

  case "$shell" in
  zsh)
    cat <<'PREAMBLE'
# agentic zsh completion - generated by: agentic completion zsh
# Add to .zshrc:  source <(agentic completion zsh)
PREAMBLE
    cat <<BODY
_agentic() {
  local state

  _arguments -C \\
    '(-h --help)'{-h,--help}'[show help]' \\
    '--home[override tool home directory]:directory:_directories' \\
    '(--volume -v)'{--volume,-v}'[mount extra volume (bind or named volume)]:spec' \\
    '--pids-limit[override container PID limit]:limit' \\
    '--cpus[override CPU limit]:cpus' \\
    '--memory[override memory limit]:size' \\
    '1: :->command' \\
    '*:: :->args'

  case \$state in
    command)
      local -a commands
      if (( \${+opt_args[--home]} || \${+opt_args[--volume]} || \${+opt_args[-v]} || \${+opt_args[--pids-limit]} || \${+opt_args[--cpus]} || \${+opt_args[--memory]} )); then
        commands=(
$(for t in $tools; do printf "          '%s:run the %s CLI'\n" "$t" "$t"; done)
        )
        _describe 'tool' commands
      else
        commands=(
          'build:build tool image(s)'
          'clean:remove tool image(s)'
          'inspect:show image info'
          'update:update tool image(s) to latest version'
          'volumes:manage named Docker volumes'
          'completion:print shell completion script'
          'aliases:print shell alias definitions for tools'
          'help:show help for a command'
$(for t in $tools; do printf "          '%s:run the %s CLI'\n" "$t" "$t"; done)
        )
        _describe 'command' commands
      fi
      ;;

    args)
      case \$words[1] in
        build)
          _arguments \\
            '(-h --help)'{-h,--help}'[show help]' \\
            '--base[override extra runtimes]:extras' \\
            '--no-cache[disable Docker layer cache]' \\
            '--node[Node.js version to use]:version' \\
            '--java[Java (Temurin JDK) version to use]:version' \\
            '--dotnet[Dotnet version to use]:version' \\
            ": :(($(for t in $tools; do printf "%s:'build the %s image' " "$t" "$t"; done)))"
          ;;
        update)
          _arguments \\
            '(-h --help)'{-h,--help}'[show help]' \\
            '--base[override extra runtimes]:extras' \\
            '--no-cache[disable Docker layer cache for all steps]' \\
            '--node[Node.js version to use]:version' \\
            '--java[Java (Temurin JDK) version to use]:version' \\
            '--dotnet[Dotnet version to use]:version' \\
            ": :(($(for t in $tools; do printf "%s:'update the %s image' " "$t" "$t"; done)))"
          ;;
        clean|inspect)
          _arguments '(-h --help)'{-h,--help}'[show help]' ": :(($(for t in $tools; do printf "%s:'%s' " "$t" "$t"; done)))"
          ;;
        volumes)
          case \$words[2] in
            remove|rm)
              local vols
              vols=(\${(f)"\$(docker volume ls -q --filter 'label=project=agentic-cli' 2>/dev/null)"})
              _describe 'volume' vols
              ;;
            *)
              _arguments ": :(create list ls remove rm)"
              ;;
          esac
          ;;
        help)
          _arguments ": :(build update clean inspect volumes completion aliases run)"
          ;;
        completion)
          _arguments '(-h --help)'{-h,--help}'[show help]' ": :(bash zsh)"
          ;;
        *)
          if (( \${words[(I)--]} )); then
            _command_names -e
          elif [[ \$words[1] == -* ]]; then
            _arguments \\
              '(-h --help)'{-h,--help}'[show help]' \\
              '--home[override tool home directory]:directory:_directories' \\
              '(--volume -v)'{--volume,-v}'[mount extra volume (bind or named volume)]:spec' \\
              '--pids-limit[override container PID limit]:limit' \\
              '--cpus[override CPU limit]:cpus' \\
              '--memory[override memory limit]:size' \\
              ": :(($(for t in $tools; do printf "%s:'run the %s CLI' " "$t" "$t"; done)))"
          else
            _arguments ': :(--)'
          fi
          ;;
      esac
      ;;
  esac
}

compdef _agentic agentic
BODY
    ;;

  bash)
    cat <<'PREAMBLE'
# agentic bash completion - generated by: agentic completion bash
# Add to .bashrc:  source <(agentic completion bash)
PREAMBLE
    cat <<BODY
_agentic_complete() {
  local cur prev
  cur="\${COMP_WORDS[COMP_CWORD]}"
  prev="\${COMP_WORDS[COMP_CWORD-1]}"

  local tools="${tools}"
  local commands="build clean inspect update volumes completion aliases help \${tools}"

  if [[ \$COMP_CWORD -eq 1 ]]; then
    COMPREPLY=(\$(compgen -W "--help \${commands}" -- "\$cur"))
    return
  fi

  case "\${COMP_WORDS[1]}" in
    build)
      case "\$prev" in
        --base|--node|--java|--dotnet) COMPREPLY=(); return ;;
        *)      COMPREPLY=(\$(compgen -W "\${tools} --base --no-cache --node --java --dotnet --help" -- "\$cur")) ;;
      esac
      ;;
    update)
      case "\$prev" in
        --base|--node|--java|--dotnet) COMPREPLY=(); return ;;
        *)      COMPREPLY=(\$(compgen -W "\${tools} --base --no-cache --node --java --dotnet --help" -- "\$cur")) ;;
      esac
      ;;
    clean|inspect)
      COMPREPLY=(\$(compgen -W "\${tools} --help" -- "\$cur"))
      ;;
    volumes)
      case "\${COMP_WORDS[2]}" in
        remove|rm)
          local vols
          vols=\$(docker volume ls -q --filter "label=project=agentic-cli" 2>/dev/null)
          COMPREPLY=(\$(compgen -W "\$vols" -- "\$cur"))
          ;;
        *)
          COMPREPLY=(\$(compgen -W "create list ls remove rm" -- "\$cur"))
          ;;
      esac
      ;;
    help)
      COMPREPLY=(\$(compgen -W "build update clean inspect volumes completion aliases run" -- "\$cur"))
      ;;
    completion)
      COMPREPLY=(\$(compgen -W "bash zsh --help" -- "\$cur"))
      ;;
    *)
      local i has_dashdash=0
      for (( i=1; i<COMP_CWORD; i++ )); do
        [[ "\${COMP_WORDS[i]}" == "--" ]] && has_dashdash=1 && break
      done
      if [[ "\$has_dashdash" -eq 1 ]]; then
        COMPREPLY=(\$(compgen -c -- "\$cur"))
      elif [[ "\${COMP_WORDS[1]}" == -* ]]; then
        case "\$prev" in
          --home) COMPREPLY=(\$(compgen -d -- "\$cur")); return ;;
          --pids-limit|--cpus|--memory|--volume|-v) COMPREPLY=(); return ;;
        esac
        COMPREPLY=(\$(compgen -W "\${tools} --help --home --volume -v --pids-limit --cpus --memory" -- "\$cur"))
      else
        COMPREPLY=(\$(compgen -W "--" -- "\$cur"))
      fi
      ;;
  esac
}

complete -F _agentic_complete agentic
BODY
    ;;

  *)
    echo "Error: unsupported shell '$shell'. Supported: bash, zsh" >&2
    exit 1
    ;;
  esac
}

# --- Dispatch ---
# Route build/clean/inspect/completion commands before run-specific argument parsing.
COMMAND="${1:-}"

case "$COMMAND" in
-h | --help)
  usage
  exit 0
  ;;

build)
  exec agentic-cli build "${@:2}"
  ;;

update)
  exec agentic-cli update "${@:2}"
  ;;

clean)
  exec agentic-cli clean "${@:2}"
  ;;

inspect)
  exec agentic-cli inspect "${@:2}"
  ;;

completion)
  handle_help completion "${2:-}"
  cmd_completion "${2:-}"
  exit 0
  ;;

aliases)
  exec agentic-cli aliases "${@:2}"
  ;;

volumes)
  exec agentic-cli volumes "${@:2}"
  ;;

help)
  cmd_help "${2:-}"
  exit 0
  ;;
esac

# --- Run ---
if ! command -v agentic-cli >/dev/null 2>&1; then
  echo "Error: agentic-cli not found on PATH. Install it with 'make install'."
  exit 1
fi
exec agentic-cli run "$@"
