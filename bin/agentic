#!/usr/bin/env bash
set -euo pipefail

# --- Usage ---
usage() {
  cat <<EOF
Usage: agentic <command> [args...]

Build, clean, and run agentic tools in sandboxed Docker containers.

Commands:
  build        Build tool image(s)
  update       Update tool image(s) to latest version
  clean        Remove tool image(s)
  inspect      Show image info
  volumes      Manage named Docker volumes
  completion   Print shell completion script
  aliases      Print shell alias definitions for tools
  help         Show help for a command
  <tool>       Run a tool (claude, copilot, opencode)
               Use 'agentic help run' for run options.

Run 'agentic help <command>' for command-specific help.
EOF
}

# --- Help ---
cmd_help() {
  case "${1:-}" in
  build) exec agentic-cli build --help ;;
  update) exec agentic-cli update --help ;;
  clean) exec agentic-cli clean --help ;;
  inspect) exec agentic-cli inspect --help ;;
  volumes) exec agentic-cli volumes --help ;;
  completion) exec agentic-cli completion --help ;;
  aliases) exec agentic-cli aliases --help ;;
  run) exec agentic-cli run --help ;;
  help | "") usage ;;
  *)
    echo "Error: unknown command '${1}'"
    echo ""
    usage
    exit 1
    ;;
  esac
}

# --- Dispatch ---
# Route subcommands before run-specific argument parsing.
COMMAND="${1:-}"

case "$COMMAND" in
-h | --help)
  usage
  exit 0
  ;;

build)
  exec agentic-cli build "${@:2}"
  ;;

update)
  exec agentic-cli update "${@:2}"
  ;;

clean)
  exec agentic-cli clean "${@:2}"
  ;;

inspect)
  exec agentic-cli inspect "${@:2}"
  ;;

completion)
  exec agentic-cli completion "${@:2}"
  ;;

aliases)
  exec agentic-cli aliases "${@:2}"
  ;;

volumes)
  exec agentic-cli volumes "${@:2}"
  ;;

help)
  cmd_help "${2:-}"
  exit 0
  ;;
esac

# --- Run ---
if ! command -v agentic-cli >/dev/null 2>&1; then
  echo "Error: agentic-cli not found on PATH. Install it with 'make install'."
  exit 1
fi
exec agentic-cli run "$@"
